<%- include('partials/header') %>

    <main class="main-content" style="min-height: 70vh;">
        <section class="pricing-section bg-light">
            <div class="container">
                <div class="section-header reveal reveal-up reveal-visible">
                    <h1 class="section-title">Rozkład Jazdy</h1>
                    <div class="title-underline"></div>
                </div>

                <div class="schedule-page-grid reveal reveal-up reveal-visible">
                    <!-- Column 2: departures from miejscowosc1 (direction miejscowosc2) -->
                    <div class="schedule-column">
                        <h2 class="schedule-column-title">miejscowosc1 - miejscowosc2 - miejscowosc4 - miejscowosc7</h2>

                        <!-- Dni robocze -->
                        <div class="schedule-day-section">
                            <% const sWorkdays=(schedule && schedule.sulkowice && schedule.sulkowice.workdays) ?
                                schedule.sulkowice.workdays : []; const sC_w=3; const sR_w=Math.ceil(sWorkdays.length /
                                sC_w); %>
                                <details class="schedule-details" open>
                                    <summary class="schedule-summary">
                                        <span>Poniedziałek - Piątek (dni robocze)</span>
                                        <svg class="chevron" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                            <path d="M7 10l5 5 5-5z" />
                                        </svg>
                                    </summary>
                                    <div class="schedule-table-wrapper">
                                        <table class="schedule-table">
                                            <tbody>
                                                <% if (sWorkdays.length> 0) { %>
                                                    <% for (let r=0; r < sR_w; r++) { %>
                                                        <tr>
                                                            <% for (let c=0; c < sC_w; c++) { %>
                                                                <% const idx=c * sR_w + r; %>
                                                                    <td>
                                                                        <% if (idx < sWorkdays.length) { %>
                                                                            <span class="time-val">
                                                                                <%= sWorkdays[idx].time %>
                                                                            </span>
                                                                            <% if (sWorkdays[idx].notes &&
                                                                                sWorkdays[idx].notes.length> 0) { %>
                                                                                <% sWorkdays[idx].notes.forEach(note=> {
                                                                                    %>
                                                                                    <% if (attributes.some(a=> a.symbol
                                                                                        === note)) { %>
                                                                                        <span class="attr-tag">
                                                                                            <%= note %>
                                                                                        </span>
                                                                                        <% } %>
                                                                                            <% }) %>
                                                                                                <% } %>
                                                                                                    <% } else { %>
                                                                                                        <span
                                                                                                            class="no-time">-</span>
                                                                                                        <% } %>
                                                                    </td>
                                                                    <% } %>
                                                        </tr>
                                                        <% } %>
                                                            <% } else { %>
                                                                <tr>
                                                                    <td colspan="<%= sC_w %>" class="no-courses-cell">
                                                                        Brak zaplanowanych kursów.</td>
                                                                </tr>
                                                                <% } %>
                                            </tbody>
                                        </table>
                                    </div>
                                </details>
                        </div>

                        <!-- Soboty -->
                        <div class="schedule-day-section">
