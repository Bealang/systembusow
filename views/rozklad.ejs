    </main>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const getIsMobile = () => window.innerWidth <= 768;
            let isMobile = getIsMobile();

            function updateDetailsState(mobile) {
                const detailsElements = document.querySelectorAll('.schedule-details');
                detailsElements.forEach(details => {
                    if (mobile) {
                        details.removeAttribute('open');
                    } else {
                        details.setAttribute('open', '');
                    }
                });
            }

            // Initial state based on current viewport
            updateDetailsState(isMobile);

            // Listen to resize events to automatically toggle state when crossing the boundary
            window.addEventListener('resize', () => {
                const currentMobile = getIsMobile();
                if (currentMobile !== isMobile) {
                    isMobile = currentMobile;
                    updateDetailsState(isMobile);
                }
            });
        });
    </script>

