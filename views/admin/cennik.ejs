<!DOCTYPE html>
<html lang="pl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bodzio - Cennik (Zarządzanie)</title>
    <link rel="shortcut icon" href="/favicon.jpg" type="image/jpeg">
    <link rel="icon" href="/favicon.jpg" type="image/jpeg">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/admin.css">
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
</head>

<body>
    <%- include('partials/sidebar', { activePage: 'cennik' }) %>

        <div class="admin-container admin-main-area" id="admin-panel" style="display: block !important;">
            <div id="notification-container"></div>

            <!-- Edytor Cennika -->
            <div id="tab-pricing" class="tab-content active">
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 30px;">
                    <!-- Zarządzanie przystankami -->
                    <div
                        style="background: white; padding: 20px; border-radius: var(--radius-box); border: 1px solid var(--admin-border); box-shadow: var(--shadow-soft);">
                        <h3>Zarządzanie Przystankami</h3>
                        <form id="add-stop-form" style="display: flex; gap: 10px; margin-bottom: 20px;">
                            <input type="text" id="new-stop-name" placeholder="Nazwa przystanku..."
                                style="flex: 1; padding: 12px; border: 1.5px solid var(--admin-border); background: #f8fafc;"
                                required>
                            <button type="submit" class="btn-primary" style="padding: 12px 24px;">Dodaj</button>
                        </form>
                        <div id="stops-list-container" style="max-height: 400px; overflow-y: auto;">
                            <!-- Lista przystanków -->
                            <p style="color: var(--text-secondary); font-size: 0.9rem;">Ładowanie przystanków...</p>
                        </div>
                    </div>

                    <!-- Edytor cen relacji -->
                    <div
                        style="background: white; padding: 20px; border-radius: var(--radius-box); border: 1px solid var(--admin-border); box-shadow: var(--shadow-soft);">
                        <h3>Edytor cen</h3>
                        <div class="form-group">
                            <label for="price-stop-a">Przystanek A</label>
                            <select id="price-stop-a"
                                style="padding: 12px; border: 1.5px solid var(--admin-border); background: #f8fafc;"></select>
                        </div>
                        <div class="form-group">
                            <label id="label-stop-b" for="price-stop-b">Przystanek B</label>
                            <select id="price-stop-b"
                                style="padding: 12px; border: 1.5px solid var(--admin-border); background: #f8fafc;"></select>
                        </div>

                        <div id="price-inputs" style="margin-top: 20px; padding-top: 20px; border-top: 1px solid #eee;">
                            <div class="form-group">
                                <label for="price-s">Bilet jednorazowy (zł)</label>
                                <input type="number" step="0.10" id="price-s" placeholder="np. 6.50"
                                    style="padding: 12px; border: 1.5px solid var(--admin-border); background: #f8fafc;">
                            </div>
                            <button type="button" id="save-price-btn" class="btn-primary"
                                style="width: 100%;">Zapisz</button>
                        </div>
                    </div>
                </div>

                <!-- Szybka zmiana cen w cenniku -->
                <div
                    style="margin-top: 30px; background: white; padding: 20px; border-radius: var(--radius-box); border: 1px solid var(--admin-border); box-shadow: var(--shadow-soft);">
                    <h3>Szybka zmiana cen</h3>
                    <p style="margin-bottom: 20px; color: var(--text-secondary); font-size: 0.95rem;">Zwiększ lub
                        zmniejsz ceny o wybraną kwotę
                        dla wszystkich biletów jednorazowych. Użyj ujemnej wartości (np. -2.00) aby obniżyć ceny.
                    </p>
                    <div style="display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap;">
                        <div class="form-group" style="margin-bottom: 0; min-width: 200px;">
                            <label for="bulk-price-amount">Kwota zmiany (zł)</label>
                            <input type="number" step="0.10" id="bulk-price-amount" placeholder="np. 2.00 lub -1.50"
                                style="padding: 12px; border: 1.5px solid var(--admin-border); background: #f8fafc;"
                                required>
                        </div>
                        <button type="button" id="bulk-price-btn" class="btn-primary"
                            style="padding: 12px 24px; height: 46px;">Nadpisz ceny</button>
                    </div>
                </div>

                <!-- Konfiguracja cennika -->
                <div
                    style="margin-top: 30px; background: white; padding: 25px; border-radius: var(--radius-box); border: 1px solid var(--admin-border); box-shadow: var(--shadow-soft);">
                    <h3 style="margin-top: 0; margin-bottom: 8px;">Ustawienia biletów miesięcznych</h3>
                    <p style="margin-bottom: 25px; color: var(--text-secondary); font-size: 0.95rem;">
                        Określ przelicznik ceny biletu miesięcznego
                    </p>

                    <!-- Przelicznik -->
                    <div class="form-group"
                        style="margin-bottom: 30px; background: #f8fafc; padding: 18px; border-radius: 8px; border: 1px solid #e2e8f0;">
                        <label style="font-weight: 600; display: block; margin-bottom: 8px; color: #1e293b;"
                            for="config-multiplier">Wartość biletu miesięcznego</label>
                        <div style="display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
                            <input type="number" step="1" id="config-multiplier" placeholder="40" required
                                style="width: 90px; padding: 8px 12px; text-align: center; font-weight: 700; font-size: 1.1rem; border: 1px solid #cbd5e1; border-radius: 6px; background: white;">
                            <span style="font-weight: 600; color: #334155; font-size: 0.95rem;">biletów
                                jednorazowych</span>
                        </div>
                    </div>

                    <!-- Ulgi Header & List -->
                    <div style="margin-bottom: 25px;">
                        <h3 style="margin-top: 0; margin-bottom: 8px;">Dostępne ulgi</h3>
                        <p style="margin-bottom: 16px; color: var(--text-secondary); font-size: 0.95rem;">
                            Zarządzaj dostępnymi ulgami i ich wysokością
                        </p>

                        <!-- Checkbox: ulgi na bilety jednorazowe -->
                        <label for="config-discounts-single" style="display: flex; align-items: center; gap: 12px; padding: 14px 16px; background: #f0f9ff; border: 1.5px solid #bae6fd; border-radius: 8px; cursor: pointer; margin-bottom: 20px; user-select: none;">
                            <input type="checkbox" id="config-discounts-single"
                                style="width: 18px; height: 18px; accent-color: var(--primary-color); cursor: pointer; flex-shrink: 0;">
                            <span style="font-size: 0.95rem; color: #0369a1; font-weight: 600; line-height: 1.4;">
                                Ulgi dotyczą również biletów jednorazowych
                                <span style="display: block; font-weight: 400; color: #0c4a6e; font-size: 0.85rem; margin-top: 2px;">
                                    Gdy zaznaczone, kalkulator pokaże obniżone ceny biletów jednorazowych przy wybranej uldze
                                </span>
                            </span>
                        </label>

                        <div
                            style="display: grid; grid-template-columns: 2fr 1fr 100px; gap: 12px; font-weight: 600; padding: 0 14px 8px 14px; border-bottom: 2px solid #e2e8f0; color: #64748b; font-size: 0.85rem; text-transform: uppercase;">
                            <div>Nazwa ulgi</div>
                            <div>Wysokość ulgi (%)</div>
                            <div style="text-align: right;">Akcja</div>
                        </div>

                        <div id="discounts-list-container"
                            style="margin-top: 10px; margin-bottom: 20px; display: flex; flex-direction: column; gap: 10px;">
                            <!-- Lista ulg ładowana dynamicznie -->
                            <p style="color: var(--text-secondary); font-size: 0.9rem;">Ładowanie ulg...</p>
                        </div>

                        <!-- Formularz dodawania ulgi -->
                        <div
                            style="background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 8px; padding: 16px; margin-top: 15px;">
                            <span
                                style="font-weight: 600; font-size: 0.85rem; color: #475569; display: block; margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.03em;">Dodaj
                                nową ulgę</span>
                            <form id="add-discount-form"
                                style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
                                <div style="flex: 2; min-width: 200px;">
                                    <input type="text" id="new-discount-name"
                                        placeholder="Nazwa nowej ulgi (np. Studencka)"
                                        style="width: 100%; padding: 12px; border: 1.5px solid var(--admin-border); background: #f8fafc; font-size: 0.95rem; transition: border-color 0.2s;"
                                        required>
                                </div>
                                <div style="display: flex; align-items: center; gap: 6px; flex: 1; min-width: 130px;">
                                    <input type="number" id="new-discount-percent" placeholder="51"
                                        style="width: 90px; padding: 12px; border: 1.5px solid var(--admin-border); background: #f8fafc; text-align: center; font-weight: 700; font-size: 0.95rem; transition: border-color 0.2s;"
                                        required min="0" max="100">
                                    <span style="font-weight: 700; color: #64748b; font-size: 1rem;">%</span>
                                </div>
                                <button type="submit" class="btn-primary"
                                    style="padding: 12px 24px; font-size: 0.95rem; font-weight: 600; white-space: nowrap; border-radius: 6px; display: inline-flex; align-items: center; gap: 6px; height: 46px;">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                        <line x1="12" y1="5" x2="12" y2="19"></line>
                                        <line x1="5" y1="12" x2="19" y2="12"></line>
                                    </svg>
                                    Dodaj ulgę
                                </button>
                            </form>
                        </div>
                    </div>

                    <div
                        style="border-top: 1px solid #e2e8f0; padding-top: 20px; display: flex; justify-content: flex-end;">
                        <button type="button" id="save-pricing-config-btn" class="btn-primary"
                            style="padding: 12px 28px; font-size: 1rem; font-weight: 600;">Zapisz</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Unsaved changes warning badge -->
        <div id="unsaved-changes-badge" style="display: none;">
            <div class="unsaved-badge-icon-circle">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
                    stroke-linecap="round" stroke-linejoin="round">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z">
                    </path>
                    <line x1="12" y1="9" x2="12" y2="13"></line>
                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
            </div>
            <span>Uwaga! Masz niezapisane zmiany</span>
        </div>

        <script type="module" src="/js/admin/main.js?v=<%= Date.now() %>"></script>
</body>

</html>