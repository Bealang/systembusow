<!DOCTYPE html>
<html lang="pl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TwojaNazwa - Rozkład Jazdy (Zarządzanie)</title>
    <link rel="shortcut icon" href="/favicon.jpg" type="image/jpeg">
    <link rel="icon" href="/favicon.jpg" type="image/jpeg">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/admin.css">
</head>

<body>
    <%- include('partials/sidebar', { activePage: 'rozklad-jazdy' }) %>

    <div class="admin-container admin-main-area" id="admin-panel" style="display: block !important;">
        <div id="notification-container"></div>

        <div id="tab-schedule-builder" class="tab-content active">

            <!-- Zdjęcie rozkładu -->
            <div style="background: white; padding: 24px; border-radius: var(--radius-box); border: 1px solid var(--admin-border); margin-bottom: 28px; box-shadow: var(--shadow-soft);">
                <div class="schedule-upload-wrap">
                    <div style="flex: 1; min-width: 200px;">
                        <h3 style="margin: 0 0 6px 0; font-size: 1.05rem;">Zdjęcie rozkładu jazdy</h3>
                        <p style="margin: 0; color: var(--text-secondary); font-size: 0.88rem; line-height: 1.5;">
                            Aktualizuj zdjęcie rozkładu widniejące na stronie. Akceptowane formaty: <strong>PNG, JPG, WebP, AVIF</strong>
                        </p>
                        <div style="margin-top: 12px; display: flex; align-items: center; gap: 8px;">
                            <input type="checkbox" id="toggle-schedule-image-checkbox" style="width: 18px; height: 18px; cursor: pointer;">
                            <label for="toggle-schedule-image-checkbox" style="font-size: 0.9rem; font-weight: 500; cursor: pointer; color: var(--text-primary);">
                                Pokazuj zdjęcie rozkładu
                            </label>
                        </div>
                    </div>
                    <form id="upload-form" class="schedule-upload-form">
                        <input type="file" id="rozklad_image" accept="image/png, image/jpeg, image/webp, image/avif"
                            required style="padding: 10px 12px; border: 1.5px solid var(--admin-border); background: #f8fafc; font-size: 0.9rem;">
                        <button type="submit" class="btn-primary" style="height: 44px; padding: 0 20px; white-space: nowrap;">
                            Aktualizuj zdjęcie
                        </button>
                    </form>
                </div>
            </div>

            <!-- Edytor kursów -->
            <div style="background: white; padding: 28px; border-radius: var(--radius-box); border: 1px solid var(--admin-border); box-shadow: var(--shadow-soft);">
                <div style="margin-bottom: 22px;">
                    <h3 style="margin: 0 0 6px 0; font-size: 1.05rem;">Zarządzanie kursami</h3>
                    <p style="margin: 0; color: var(--text-secondary); font-size: 0.88rem;">Wybierz kierunek i dzień, wczytaj kursy, a następnie dodaj, edytuj lub usuń wpisy.</p>
                </div>

                <!-- Toolbar: filtry + load -->
                <div class="schedule-toolbar">
                    <div class="schedule-filter-group">
                        <label for="schedule-city-select">Kierunek</label>
                        <select id="schedule-city-select">
                            <option value="myslenice">do miejscowosc2</option>
                            <option value="sulkowice">do miejscowosc1</option>
                        </select>
                    </div>
                    <div class="schedule-filter-group">
                        <label for="schedule-day-select">Dzień</label>
                        <select id="schedule-day-select">
                            <option value="workdays">Poniedziałek – Piątek</option>
                            <option value="saturday">Sobota</option>
                            <option value="sunday">Niedziele i święta</option>
                        </select>
                    </div>
                    <button type="button" id="load-schedule-view" class="btn-primary" style="height: 44px; padding: 0 24px; display: inline-flex; align-items: center; gap: 8px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <polyline points="1 4 1 10 7 10"></polyline>
                            <path d="M3.51 15a9 9 0 1 0 .49-3.51"></path>
                        </svg>
                        Wczytaj kursy
                    </button>
                </div>

                <!-- Status bar (shows after load) -->
                <div id="schedule-status-bar" class="schedule-status-bar" style="display: none;">
                    <span style="font-size: 0.88rem; color: #0369a1; font-weight: 600;">
                        Wyświetlono: <span id="schedule-course-count" style="font-weight: 800;">0</span> kursów
                    </span>
                    <span style="font-size: 0.82rem; color: #0c4a6e;">Zmiany są lokalne — kliknij „Zapisz zmiany" aby opublikować</span>
                </div>

                <!-- Tabela kursów -->
                <div class="schedule-editor-area">
                    <div id="schedule-table-container">
                        <div class="empty-state">
                            <svg xmlns="http://www.w3.org/2000/svg" width="44" height="44" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                stroke-linejoin="round" style="margin-bottom: 12px; opacity: 0.4;">
                                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                <line x1="16" y1="2" x2="16" y2="6"></line>
                                <line x1="8" y1="2" x2="8" y2="6"></line>
                                <line x1="3" y1="10" x2="21" y2="10"></line>
                            </svg>
                            <p style="margin: 0; font-weight: 600; font-size: 0.95rem; color: #475569;">Brak wczytanych kursów</p>
                            <p style="margin: 6px 0 0 0; font-size: 0.85rem; color: #94a3b8;">Wybierz kierunek i dzień, a następnie kliknij „Wczytaj kursy".</p>
                        </div>
                    </div>

                    <div class="schedule-actions-bottom">
                        <button type="button" id="add-schedule-row" class="btn-outline" style="display: none;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="12" y1="5" x2="12" y2="19"></line>
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                            <span>Nowy kurs</span>
                        </button>
                        <button type="button" id="save-schedule-btn" class="btn-primary schedule-save-btn" style="display: none;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                                <polyline points="17 21 17 13 7 13 7 21"></polyline>
                                <polyline points="7 3 7 8 15 8"></polyline>
                            </svg>
                            Zapisz zmiany
                        </button>
                    </div>
                </div>
            </div>

            <!-- Zarządzanie atrybutami kursów -->
            <div style="background: white; padding: 28px; border-radius: var(--radius-box); border: 1px solid var(--admin-border); margin-top: 28px; box-shadow: var(--shadow-soft);">
                <div style="margin-bottom: 22px;">
                    <h3 style="margin: 0 0 6px 0; font-size: 1.05rem;">Oznaczenia kursów</h3>
                    <p style="margin: 0; color: var(--text-secondary); font-size: 0.88rem;">Zarządzaj symbolami, które możesz przypisać do konkretnych godzin odjazdów.</p>
                </div>

                <form id="add-attribute-form"
                    style="display: flex; gap: 12px; align-items: flex-end; margin-bottom: 24px; flex-wrap: wrap; padding: 16px; background: #f8fafc; border: 1px dashed #cbd5e1; border-radius: 6px;">
                    <div class="form-group" style="margin-bottom: 0; min-width: 110px; flex: 1;">
                        <label for="new-attr-symbol" style="font-size: 0.82rem; font-weight: 600; color: #475569; display: block; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.04em;">Symbol</label>
                        <input type="text" id="new-attr-symbol" placeholder="np. HS" required maxlength="5"
                            style="border: 1.5px solid var(--admin-border); padding: 11px 12px; width: 100%; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">
                    </div>
                    <div class="form-group" style="margin-bottom: 0; min-width: 240px; flex: 3;">
                        <label for="new-attr-desc" style="font-size: 0.82rem; font-weight: 600; color: #475569; display: block; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.04em;">Krótki opis</label>
                        <input type="text" id="new-attr-desc" placeholder="np. kurs szkolny" required
                            style="border: 1.5px solid var(--admin-border); padding: 11px 12px; width: 100%;">
                    </div>
                    <button type="submit" class="btn-primary" style="height: 44px; padding: 0 20px; display: inline-flex; align-items: center; gap: 6px; white-space: nowrap; flex-shrink: 0;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                        Dodaj oznaczenie
                    </button>
                </form>

                <div id="attributes-list-container">
                    <p style="color: var(--text-secondary); font-size: 0.9rem;">Ładowanie oznaczeń...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Unsaved changes warning badge -->
    <div id="unsaved-changes-badge" style="display: none;">
        <div class="unsaved-badge-icon-circle">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
                stroke-linecap="round" stroke-linejoin="round">
                <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
                <line x1="12" y1="9" x2="12" y2="13"></line>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
        </div>
        <span>Uwaga! Masz niezapisane zmiany</span>
    </div>

    <!-- Modal dla dodawania kursu -->
    <div id="add-course-modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Dodaj nowy kurs</h3>
                <button type="button" class="close-modal-btn">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label for="new-course-time">Godzina odjazdu</label>
                    <input type="time" id="new-course-time" value="12:00" required style="padding: 12px; border: 1.5px solid var(--admin-border);">
                </div>
                <div class="form-group">
                    <label>Oznaczenia</label>
                    <div class="schedule-tags-wrap" id="modal-attributes-container"
                        style="background: transparent; border: none; padding: 0;">
                        <!-- Dynamicznie ładowane atrybuty -->
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-primary" id="confirm-add-course">Dodaj</button>
            </div>
        </div>
    </div>

    <script type="module" src="/js/admin/main.js?v=<%= Date.now() %>"></script>
</body>

</html>
