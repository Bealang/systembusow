<!DOCTYPE html>
<html lang="pl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TwojaNazwa - Logowanie</title>
    <link rel="shortcut icon" href="/favicon.jpg" type="image/jpeg">
    <link rel="icon" href="/favicon.jpg" type="image/jpeg">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/admin.css">
</head>

<body>
    <!-- Login Screen -->
    <div class="login-screen-wrapper" id="login-screen" style="display: flex !important;">
        <div class="login-card">
            <div class="login-logo">
                <h1>TwojaNazwa</h1>
            </div>
            <div id="login-alert" class="alert"></div>
            
            <form id="login-form">
                <div class="form-group">
                    <input type="text" id="username" placeholder="Nazwa użytkownika lub e-mail" required autocomplete="username">
                </div>
                <div class="form-group" style="margin-bottom: 15px;">
                    <input type="password" id="password" placeholder="Hasło" required autocomplete="current-password">
                </div>

                <div style="text-align: right; margin-bottom: 25px;">
                    <button type="button" id="btn-show-forgot" style="background: none; border: none; color: #2563eb; font-size: 0.85rem; font-weight: 500; cursor: pointer; text-decoration: underline;">
                        Nie pamiętam hasła
                    </button>
                </div>

                <button type="submit" class="login-btn">Zaloguj się</button>
            </form>

            <!-- Formularz Zapomniałem hasła (ukryty domyślnie) -->
            <form id="forgot-form" style="display: none; margin-top: 10px;">
                <p style="font-size: 0.9rem; color: #64748b; margin-bottom: 15px; text-align: center;">
                    Podaj adres E-mail przypisany do konta, aby wysłać link resetujący hasło.
                </p>
                <div class="form-group" style="margin-bottom: 20px;">
                    <input type="email" id="forgot-email" placeholder="Twój adres e-mail" required autocomplete="email">
                </div>
                <button type="submit" class="login-btn" style="margin-bottom: 15px;">Wyślij link</button>
                <button type="button" id="btn-hide-forgot" style="width: 100%; background: #e2e8f0; color: #334155; border: none; padding: 12px; border-radius: var(--radius-btn); font-weight: 600; cursor: pointer;">
                    Anuluj
                </button>
            </form>

        </div>
    </div>

    <script type="module" src="/js/admin/login.js?v=<%= Date.now() %>"></script>
</body>

</html>
