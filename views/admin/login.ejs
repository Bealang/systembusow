<!DOCTYPE html>
<html lang="pl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TwojaNazwa - Logowanie</title>
    <link rel="shortcut icon" href="/favicon.jpg" type="image/jpeg">
    <link rel="icon" href="/favicon.jpg" type="image/jpeg">
    <link rel="stylesheet" href="/style.css">
    <link rel="stylesheet" href="/admin.css">
</head>

<body>
    <!-- Login Screen -->
    <div class="login-screen-wrapper" id="login-screen" style="display: flex !important;">
        <div class="login-card">
            <div class="login-logo">
                <h1>TwojaNazwa</h1>
            </div>
            <div id="login-alert" class="alert"></div>
            <form id="login-form">
                <div class="form-group">
                    <input type="text" id="username" placeholder="Nazwa użytkownika" required autocomplete="username">
                </div>
                <div class="form-group" style="margin-bottom: 30px;">
                    <input type="password" id="password" placeholder="Hasło" required autocomplete="current-password">
                </div>
                <button type="submit" class="login-btn">Zaloguj się</button>
            </form>
        </div>
    </div>

    <script type="module" src="/js/admin/main.js?v=<%= Date.now() %>"></script>
</body>

</html>
