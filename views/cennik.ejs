<%- include('partials/header') %>

    <main class="main-content" style="min-height: 70vh;">
        <!-- Pricing Section -->
        <section class="pricing-section bg-light" id="cennik">
            <div class="container">
                <div class="section-header reveal reveal-up">
                    <h1 class="section-title">Cennik Biletów</h1>
                    <div class="title-underline"></div>
                </div>

                <div class="pricing-calculator reveal reveal-scale">
                    <div class="calc-form">
                        <div class="calc-group">
                            <label>Przystanek początkowy:</label>
                            <div class="custom-select" data-target="calc-from">
                                <div class="select-selected">-- Wybierz --</div>
                                <div class="select-items select-hide" id="items-from">
                                    <!-- Dynamicznie ładowane przystanki -->
                                </div>
                            </div>
                            <input type="hidden" id="calc-from" value="">
                        </div>

                        <div class="calc-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round">
                                <path d="M5 12h14"></path>
                                <path d="m12 5 7 7-7 7"></path>
                            </svg>
                        </div>

                        <div class="calc-group">
                            <label>Przystanek końcowy:</label>
                            <div class="custom-select" data-target="calc-to">
                                <div class="select-selected">-- Wybierz --</div>
                                <div class="select-items select-hide" id="items-to">
                                    <!-- Dynamicznie ładowane przystanki -->
                                </div>
                            </div>
                            <input type="hidden" id="calc-to" value="">
                        </div>
                    </div>

                    <div id="calc-results" class="calc-results hidden">
                        <div id="price-toggle-wrap" class="price-toggle-wrap">
                            <div class="price-toggle">
                                <div class="toggle-slider"></div>
                                <button type="button" class="toggle-btn active" id="toggle-normal">Normalny</button>
                                <button type="button" class="toggle-btn" id="toggle-reduced">Ulgowy (-49%)</button>
                            </div>
                        </div>

                        <div class="calc-result-card reveal reveal-scale stagger-1" id="card-single">
                            <div class="card-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <path d="M2 9V5.2A1.2 1.2 0 0 1 3.2 4h17.6A1.2 1.2 0 0 1 22 5.2V9"></path>
                                    <path d="M2 15v3.8a1.2 1.2 0 0 0 1.2 1.2h17.6a1.2 1.2 0 0 0 1.2-1.2V15"></path>
                                    <path d="M2 9c0 1.1.9 2 2 2h1"></path>
                                    <path d="M19 11h1c1.1 0 2-.9 2-2"></path>
                                    <path d="M2 15c0-1.1.9-2 2-2h1"></path>
                                    <path d="M19 13h1c1.1 0 2 0.9 2 2"></path>
                                    <line x1="12" y1="8" x2="12" y2="16"></line>
                                </svg>
                            </div>
                            <div class="card-info">
                                <h4>Bilet jednorazowy</h4>
                                <div class="price" id="price-single">-- zł</div>
                            </div>
                        </div>
                        <div class="calc-result-card highlight reveal reveal-scale stagger-2" id="card-monthly">
                            <div class="card-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                    <path d="M8 14h.01"></path>
                                    <path d="M12 14h.01"></path>
                                    <path d="M16 14h.01"></path>
                                    <path d="M8 18h.01"></path>
                                    <path d="M12 18h.01"></path>
                                    <path d="M16 18h.01"></path>
                                </svg>
                            </div>
                            <div class="card-info">
                                <h4 id="monthly-label">Miesięczny normalny</h4>
                                <div class="price" id="price-monthly">-- zł</div>
                            </div>
                        </div>
                    </div>
                    <div id="price-info-notes" class="price-info-notes hidden">
                        <div id="note-reduced" class="info-note hidden">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <line x1="12" y1="16" x2="12" y2="12"></line>
                                <line x1="12" y1="8" x2="12.01" y2="8"></line>
                            </svg>
                            <p>Do zakupu biletu miesięcznego ulgowego dla nauczycieli, uczniów i studentów uprawnia
                                tylko ważna legitymacja.</p>
                        </div>
                        <div class="info-note">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <line x1="12" y1="16" x2="12" y2="12"></line>
                                <line x1="12" y1="8" x2="12.01" y2="8"></line>
                            </svg>
                            <p>Przy zakupie biletu miesięcznego pierwszy raz wymagane jest podpisanie zgody na
                                przetwarzanie danych osobowych (RODO). Za osoby niepełnoletnie podpisuje rodzic lub
                                opiekun.</p>
                        </div>
                    </div>

                    <div id="calc-warning" class="calc-warning hidden">
                        Skontaktuj się z nami u kierowcy by dopytać o tę relację.
                    </div>
                </div>
            </div>
        </section>
    </main>

    <script src="/calculator.js" defer></script>

<%- include('partials/footer') %>
