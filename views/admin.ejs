<!DOCTYPE html>
<html lang="pl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Testbus - Panel</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <link rel="stylesheet" href="/admin.css">
</head>

<body>
    <!-- Mobile Header (Visible only on small screens) -->
    <div class="mobile-top-bar">
        <div class="logo">
            <div class="logo-text">TEST<span>BUS</span></div>
        </div>
        <button id="mobile-toggle" class="mobile-toggle">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="3" y1="12" x2="21" y2="12"></line>
                <line x1="3" y1="6" x2="21" y2="6"></line>
                <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
        </button>
    </div>

    <!-- Main Sidebar -->
    <nav class="navbar admin-sidebar" id="admin-header-main">
        <div class="sidebar-header">
            <div class="logo">
                <a href="/" style="text-decoration: none;">
                    <div class="logo-text">TEST<span>BUS</span></div>
                </a>
            </div>
        </div>

        <div class="tab-buttons">
            <button class="tab-btn" data-tab="tab-files">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"></path>
                    <polyline points="14 2 14 8 20 8"></polyline>
                </svg>
                Regulamin
            </button>
            <button class="tab-btn active" data-tab="tab-schedule-builder">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                </svg>
                Rozkład Jazdy
            </button>
            <button class="tab-btn" data-tab="tab-pricing">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="12" y1="1" x2="12" y2="23"></line>
                    <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
                </svg>
                Cennik
            </button>
            <button class="tab-btn" data-tab="tab-news">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 20l-7-7-7 7V4h14v16z"></path>
                </svg>
                Aktualności
            </button>
            <button class="tab-btn" data-tab="tab-faq">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"></circle>
                    <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                    <line x1="12" y1="17" x2="12.01" y2="17"></line>
                </svg>
                FAQ
            </button>
        </div>

        <div class="sidebar-footer">
            <a href="/" class="sidebar-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                    <polyline points="9 22 9 12 15 12 15 22"></polyline>
                </svg>
                Strona główna
            </a>
            <button id="logout-btn-header" class="btn-logout sidebar-logout">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                    <polyline points="16 17 21 12 16 7"></polyline>
                    <line x1="21" y1="12" x2="9" y2="12"></line>
                </svg>
                Wyloguj się
            </button>
        </div>
    </nav>

    <!-- Login Screen -->
    <div class="login-screen-wrapper" id="login-screen">
        <div class="login-card">
            <div class="login-logo">
                <h1>TEST<span>BUS</span></h1>
            </div>
            <div id="login-alert" class="alert"></div>
            <form id="login-form">
                <div class="form-group">
                    <input type="text" id="username" placeholder="Nazwa użytkownika" required autocomplete="username">
                </div>
                <div class="form-group" style="margin-bottom: 30px;">
                    <input type="password" id="password" placeholder="Hasło" required autocomplete="current-password">
                </div>
                <button type="submit" class="login-btn">Zaloguj się</button>
            </form>
        </div>
    </div>
    <!-- Admin Panel -->
    <div class="admin-container admin-main-area" id="admin-panel">


        <div id="notification-container"></div>

        <!-- Obsługa Plików -->
        <div id="tab-files" class="tab-content">
            <div
                style="background: white; padding: 20px; border-radius: var(--radius-box); border: 1px solid var(--admin-border);">
                <h3>Regulamin</h3>
                <p style="margin-bottom: 20px; color: var(--text-secondary);">Prześlij nową wersję regulaminu przewozów.
                    <br>
                    <strong>Format:</strong> PDF (maks. 8MB)
                </p>
                <form id="upload-regulamin-form">
                    <div class="form-group">
                        <input type="file" id="regulamin_file" accept="application/pdf" required>
                    </div>
                    <button type="submit" class="btn-primary">Aktualizuj regulamin</button>
                </form>
            </div>
        </div>

        <!-- Edytor Harmonogramu (Silnik JSON) -->
        <div id="tab-schedule-builder" class="tab-content active">
            <!-- Zdjęcie rozkładu (Przeniesione) -->
            <div
                style="background: white; padding: 20px; border-radius: var(--radius-box); border: 1px solid var(--admin-border); margin-bottom: 30px;">
                <h3>Zdjęcie rozkładu</h3>
                <p style="margin-bottom: 15px; color: var(--text-secondary);">Wybierz nową grafikę rozkładu.
                    <strong>Wskazówka:</strong> Użyj formatu <strong>WebP</strong> lub skompresuj plik PNG, aby
                    przyspieszyć ładowanie strony na telefonach.
                </p>
                <form id="upload-form">
                    <div class="form-group" style="margin-bottom: 15px;">
                        <input type="file" id="rozklad_image" accept="image/png, image/jpeg, image/webp, image/avif"
                            required>
                    </div>
                    <button type="submit" class="btn-primary" style="background: var(--primary-color);">Aktualizuj
                        zdjęcie rozkładu</button>
                </form>
            </div>

            <!-- Edytor kursów w boxie -->
            <div
                style="background: white; padding: 25px; border-radius: var(--radius-box); border: 1px solid var(--admin-border);">
                <h3 style="margin-top: 0;">Zarządzanie Kursami</h3>
                <p style="margin-bottom: 20px; color: var(--text-secondary);">Tutaj możesz dodawać, edytować i usuwać
                    godziny odjazdów dla wybranych tras.</p>

                <div class="schedule-toolbar">
                    <div class="schedule-filter-group">
                        <label for="schedule-city-select">Kierunek</label>
                        <select id="schedule-city-select">
                            <option value="myslenice">Z Miejscowość 1</option>
                            <option value="sulkowice">Z Miejscowość 2</option>
                        </select>
                    </div>
                    <div class="schedule-filter-group">
                        <label for="schedule-day-select">Dzień</label>
                        <select id="schedule-day-select">
                            <option value="workdays">Poniedziałek - Piątek</option>
                            <option value="saturday">Sobota</option>
                            <option value="sunday">Niedziele i święta</option>
                        </select>
                    </div>
                    <button type="button" id="load-schedule-view" class="btn-primary">Wczytaj Widok</button>
                </div>

                <div class="schedule-editor-area">
                    <div id="schedule-table-container">
                        <div class="empty-state">
                            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24"
                                fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                                stroke-linejoin="round">
                                <circle cx="12" cy="12" r="10"></circle>
                                <polyline points="12 6 12 12 16 14"></polyline>
                            </svg>
                            <p>Wybierz kierunek i dzień, a następnie kliknij "Wczytaj Widok".</p>
                        </div>
                    </div>

                    <div class="schedule-actions-bottom">
                        <button type="button" id="add-schedule-row" class="btn-outline" style="display: none;">
                            <span>Stwórz nowy kurs</span>
                        </button>
                        <button type="button" id="save-schedule-btn" class="btn-primary" style="display: none;">Zapisz
                            zmiany</button>
                    </div>
                </div>
            </div>

            <!-- Zarządzanie atrybutami kursów -->
            <div
                style="background: white; padding: 25px; border-radius: var(--radius-box); border: 1px solid var(--admin-border); margin-top: 30px;">
                <h3 style="margin-top: 0;">Oznaczenia kursów</h3>
                <p style="margin-bottom: 20px; color: var(--text-secondary);">Dodaj nowe oznaczenia, które
                    możesz przypisać do godzin odjazdów.</p>

                <form id="add-attribute-form"
                    style="display: flex; gap: 15px; align-items: flex-end; margin-bottom: 25px; flex-wrap: wrap;">
                    <div class="form-group" style="margin-bottom: 0; min-width: 120px; flex: 1;">
                        <label for="new-attr-symbol">Symbol (1/2 litery)</label>
                        <input type="text" id="new-attr-symbol" placeholder="np. HS" required maxlength="5"
                            style="border: 1px solid #cbd5e1; border-radius: 0;">
                    </div>
                    <div class="form-group" style="margin-bottom: 0; min-width: 250px; flex: 3;">
                        <label for="new-attr-desc">Krótki opis</label>
                        <input type="text" id="new-attr-desc" placeholder="np. kurs szkolny" required
                            style="border: 1px solid #cbd5e1; border-radius: 0;">
                    </div>
                    <button type="submit" class="btn-primary" style="height: 46px;">Dodaj atrybut</button>
                </form>

                <div id="attributes-list-container">
                    <p style="color: var(--text-secondary); font-size: 0.9rem;">Ładowanie atrybutów...</p>
                </div>
            </div>
        </div>

        <!-- Edytor Cennika -->
        <div id="tab-pricing" class="tab-content">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px;">
                <!-- Zarządzanie przystankami -->
                <div
                    style="background: white; padding: 20px; border-radius: var(--radius-box); border: 1px solid var(--admin-border);">
                    <h3>Zarządzanie Przystankami</h3>
                    <form id="add-stop-form" style="display: flex; gap: 10px; margin-bottom: 20px;">
                        <input type="text" id="new-stop-name" placeholder="Nazwa przystanku..."
                            style="flex: 1; padding: 8px;">
                        <button type="submit" class="btn-primary" style="padding: 8px 16px;">Dodaj</button>
                    </form>
                    <div id="stops-list-container" style="max-height: 400px; overflow-y: auto;">
                        <!-- Lista przystanków -->
                    </div>
                </div>

                <!-- Edytor cen relacji -->
                <div
                    style="background: white; padding: 20px; border-radius: var(--radius-box); border: 1px solid var(--admin-border);">
                    <h3>Edytor Cen Relacji</h3>
                    <div class="form-group">
                        <label>Przystanek A</label>
                        <select id="price-stop-a"></select>
                    </div>
                    <div class="form-group">
                        <label id="label-stop-b">Przystanek B</label>
                        <select id="price-stop-b"></select>
                    </div>

                    <div id="price-inputs" style="margin-top: 20px; padding-top: 20px; border-top: 1px solid #eee;">
                        <div class="form-group">
                            <label>Bilet jednorazowy (zł)</label>
                            <input type="number" step="0.10" id="price-s" placeholder="np. 6.50">
                        </div>
                        <div class="form-group">
                            <label>Bilet miesięczny (zł)</label>
                            <input type="number" step="1" id="price-m" placeholder="np. 180">
                        </div>
                        <div class="form-group">
                            <label>Miesięczny ulgowy (zł)</label>
                            <input type="number" step="1" id="price-md" placeholder="np. 140">
                        </div>
                        <button type="button" id="save-price-btn" class="btn-primary"
                            style="width: 100%;">Zapisz</button>
                    </div>
                </div>
            </div>

            <div
                style="margin-top: 30px; background: white; padding: 20px; border-radius: var(--radius-box); border: 1px solid var(--admin-border);">
                <h3>Szybka zmiana cen</h3>
                <p style="margin-bottom: 20px; color: var(--text-secondary);">Zwiększ lub zmniejsz ceny o wybraną kwotę
                    dla wszystkich biletów danego typu w systemie. Użyj ujemnej wartości (np. -2.00) aby obniżyć ceny.
                </p>
                <div style="display: flex; gap: 15px; align-items: flex-end; flex-wrap: wrap;">
                    <div class="form-group" style="margin-bottom: 0; min-width: 200px;">
                        <label>Typ biletu</label>
                        <select id="bulk-price-type">
                            <option value="s">Jednorazowy</option>
                            <option value="m">Miesięczny</option>
                        </select>
                    </div>
                    <div class="form-group" style="margin-bottom: 0; min-width: 200px;">
                        <label>Kwota zmiany (zł)</label>
                        <input type="number" step="0.10" id="bulk-price-amount" placeholder="np. 2.00 lub -1.50"
                            required>
                    </div>
                    <button type="button" id="bulk-price-btn" class="btn-primary" style="padding: 12px 24px;">Zastosuj
                        dla wszystkich</button>
                </div>
            </div>

        </div>

        <!-- Obsługa Aktualności -->
        <div id="tab-news" class="tab-content">
            <div style="display: flex; flex-direction: column; gap: 30px;">
                <!-- Formularz tworzenia -->
                <div
                    style="background: white; padding: 25px; border-radius: var(--radius-box); border: 1px solid var(--admin-border);">
                    <h3 style="margin-top: 0;">Kreator aktualności</h3>
                    <p style="margin-bottom: 25px; color: var(--text-secondary);">Użyj poniższego edytora, aby stworzyć
                        nową wiadomość/ogłoszenie na stronie głównej.
                    </p>

                    <form id="news-form">
                        <div class="form-group">
                            <label>Tytuł</label>
                            <input type="text" id="news-title" required placeholder="Wprowadź tytuł...">
                        </div>
                        <div class="form-group">
                            <label>Treść</label>
                            <div id="news-editor"
                                style="height: 300px; background: white; border: 1px solid var(--admin-border);"></div>
                        </div>
                        <button type="submit" class="btn-primary" style="padding: 15px 30px;">Opublikuj</button>
                    </form>
                </div>

                <div
                    style="background: white; padding: 25px; border-radius: var(--radius-box); border: 1px solid var(--admin-border);">
                    <h3 style="margin-top: 0; margin-bottom: 20px;">Opublikowane wiadomości</h3>
                    <div id="news-list">
                        <!-- Lista aktualności ładuje się dynamicznie -->
                    </div>
                </div>
            </div>
        </div>

        <!-- Zarządzanie FAQ -->
        <div id="tab-faq" class="tab-content">
            <div style="display: flex; flex-direction: column; gap: 30px;">
                <!-- Formularz dodawania FAQ -->
                <div
                    style="background: white; padding: 20px; border-radius: var(--radius-box); border: 1px solid var(--admin-border);">
                    <h3>Zarządzanie FAQ</h3>
                    <p style="margin-bottom: 20px; color: var(--text-secondary);">Dodaj nowe pytanie i odpowiedź do
                        sekcji FAQ na stronie głównej.</p>

                    <form id="faq-form">
                        <div class="form-group">
                            <label>Pytanie</label>
                            <input type="text" id="faq-question" placeholder="np. Jak kupić bilet jednorazowy?"
                                required>
                        </div>
                        <div class="form-group">
                            <label>Odpowiedź</label>
                            <textarea id="faq-answer" rows="4" placeholder="Wprowadź treść odpowiedzi..." required
                                style="width: 100%; padding: 10px; border: 1px solid var(--admin-border); border-radius: 4px; font-family: inherit;"></textarea>
                        </div>
                        <button type="submit" id="faq-save-btn" class="btn-primary" style="padding: 12px 24px;">Dodaj
                            pytanie FAQ</button>
                    </form>
                </div>

                <!-- Lista pytań FAQ -->
                <div
                    style="background: white; padding: 20px; border-radius: var(--radius-box); border: 1px solid var(--admin-border);">
                    <h3>Lista pytań</h3>
                    <div id="faq-list-container" style="display: flex; flex-direction: column; margin-top: 20px;">
                        <!-- Lista FAQ ładuje się dynamicznie -->
                    </div>
                </div>
            </div>
        </div>



    </div>

    <!-- Modal dla dodawania kursu -->
    <div id="add-course-modal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Dodaj Nowy Kurs</h3>
                <button type="button" class="close-modal-btn">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Godzina Odjazdu</label>
                    <input type="time" id="new-course-time" value="12:00" required>
                </div>
                <div class="form-group">
                    <label>Warianty Kursu</label>
                    <div class="schedule-tags-wrap" id="modal-attributes-container"
                        style="background: transparent; border: none; padding: 0;">
                        <!-- Dynamicznie ładowane atrybuty -->
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-primary" id="confirm-add-course">Dodaj Kurs</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
    <script src="/admin.js?v=<%= Date.now() %>"></script>
</body>

</html>