<!DOCTYPE html>
<html lang="pl">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= typeof title !=='undefined' ? title : 'Testbus' %>
    </title>
    <% if (typeof description !=='undefined' && description) { %>
        <meta name="description" content="<%= description %>">
        <% } %>
            <% if (typeof keywords !=='undefined' && keywords) { %>
                <meta name="keywords" content="<%= keywords %>">
                <% } %>
                    <link rel="preload" href="/fonts/poppins-latin-ext-400-normal.woff2" as="font" type="font/woff2" crossorigin>
                    <link rel="preload" href="/fonts/poppins-latin-ext-500-normal.woff2" as="font" type="font/woff2" crossorigin>
                    <link rel="preload" href="/fonts/poppins-latin-ext-700-normal.woff2" as="font" type="font/woff2" crossorigin>
                    <link rel="preload" href="/fonts/poppins-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin>
                    <link rel="preload" href="/fonts/poppins-latin-500-normal.woff2" as="font" type="font/woff2" crossorigin>
                    <link rel="preload" href="/fonts/poppins-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin>
                    <link rel="preload" href="/style.css?v=6" as="style">
                    <% if (typeof isHome !=='undefined' && isHome) { %>
                        <link rel="preload" href="/bus.webp" as="image" fetchpriority="high">
                        <% } %>
                            <link rel="shortcut icon" href="/favicon.jpg" type="image/jpeg">
                            <link rel="icon" href="/favicon.jpg" type="image/jpeg">
                            <link rel="stylesheet" href="/style.css?v=6">
                            <script src="/main.js?v=2" defer></script>

                            <% if (typeof isHome !=='undefined' && isHome) { %>
                                <!-- Schema.org JSON-LD for Local Business and Bus Service -->
                                <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "BusReservationService",
      "name": "Testbus",
      "url": "https://bodzio-bus.pl",
      "logo": "https://bodzio-bus.pl/bus.png",
      "description": "Przewozy osób na trasie Harbutowie, Sułkowice, Biertowice, Krzywaczka, Mogilany, Libertów, Kraków",
      "provider": {
        "@type": "LocalBusiness",
        "name": "Bodzio",
        "telephone": "+48693255722",
        "priceRange": "$",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "ul. Świętego Michała 29, 32-440 Harbutowice",
          "addressRegion": "malopolskie",
          "addressCountry": "PL"
        }
      },
      "areaServed": [
        "Harbutowice",
        "Sułkowice",
        "Biertowice",
        "Krzywaczka",
        "Mogilany",
        "Libertów",
        "Kraków"
      ]
    }
    </script>
                                <% } %>
</head>

<body>
    <!-- Navbar -->
    <nav class="navbar <%= (typeof isHome !== 'undefined' && isHome) ? 'navbar-home' : '' %>" id="main-nav">
        <div class="container nav-container">
            <div class="logo">
                <a href="/" style="text-decoration: none;">
                    <div class="logo-text">Bodzio<span> BUS</span></div>
                </a>
            </div>

            <button class="hamburger" id="hamburger-btn" aria-label="Menu">
                <span></span>
                <span></span>
                <span></span>
            </button>

            <div class="nav-links" id="nav-links">
                <a href="/rozklad"
                    class="<%= (typeof activePage !== 'undefined' && activePage === 'rozklad') ? 'active' : '' %>">Rozkład</a>
                <a href="/cennik"
                    class="<%= (typeof activePage !== 'undefined' && activePage === 'cennik') ? 'active' : '' %>">Cennik</a>
                <a
                    href="<%= (typeof isHome !== 'undefined' && isHome) ? '#aktualnosci' : '/#aktualnosci' %>">Aktualności</a>
                <a href="/regulamin.pdf" target="_blank">Regulamin</a>
                <a href="/kontakt"
                    class="<%= (typeof activePage !== 'undefined' && activePage === 'kontakt') ? 'active' : '' %>">Kontakt</a>
                <a href="https://www.facebook.com/bodzio.bus" target="_blank" aria-label="Facebook"
                    style="display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; background: rgba(255,255,255,0.1); border-radius: 50%;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
                        fill="currentColor">
                        <path
                            d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.469h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.469h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                    </svg>
                </a>
            </div>
        </div>
    </nav>