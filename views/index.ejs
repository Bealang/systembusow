<%- include('partials/header') %>

    <!-- Header / Hero section -->
    <header class="hero">
        <div class="container">
            <h1 class="hero-title reveal reveal-up stagger-1">Bodzio Bus</h1>
            <p class="reveal reveal-up stagger-2">Realizujemy połączenie na trasie Harbutowice - Kraków regularnie od ponad 25 lat.
            </p>
            <div class="reveal reveal-up stagger-3">
                <div class="btn-group-joined">
                    <a href="/rozklad" class="btn-primary"
                        style="text-decoration: none; display: inline-flex; align-items: center; justify-content: center;">Zobacz rozkład</a>
                    <button class="btn-primary-square" id="btn-show-modal" aria-label="Pokaż zdjęcie rozkładu"
                        title="Pokaż wersję graficzną rozkładu">
                        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none"
                            stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                            style="display: block;">
                            <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                            <circle cx="8.5" cy="8.5" r="1.5"></circle>
                            <polyline points="21 15 16 10 5 21"></polyline>
                        </svg>
                    </button>
                </div>
            </div>
        </div>
    </header>

    <main class="main-content" id="rozklad">
        <!-- Departures -->
        <section class="departures-section">
            <div class="container">
                <div class="section-header reveal reveal-up">
                    <h2 class="section-title">Najbliższe kursy</h2>
                    <div class="title-underline"></div>
                    <p style="text-align: center; margin-top: 1rem; color: var(--text-secondary);">Obsługujemy
                        miejscowości: Harbutowice, Sułkowice, Biertowice, Krzywaczka, Mogilany, Libertów, Kraków</p>
                </div>

                <div class="cards-grid">
                    <!-- Myślenice -->
                    <div class="departure-card reveal reveal-left stagger-1">
                        <div class="card-header">
                            <div class="route-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <circle cx="12" cy="10" r="3" />
                                    <path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 7 8 11.7z" />
                                </svg>
                            </div>
                            <div>
                                <h3>z Harbutowic</h3>
                                <span class="destination-subtext">Kierunek: Sułkowice, Krzywaczka, Kraków</span>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="time-display" id="next-myslenice-time">
                                <span class="loader"></span>
                            </div>
                            <div class="time-notes" id="next-myslenice-notes">Wczytywanie...</div>
                        </div>
                        <div class="card-footer" id="following-myslenice-info">
                            Następny: 67:67
                        </div>
                    </div>

                    <!-- Sułkowice -->
                    <div class="departure-card reveal reveal-right stagger-2">
                        <div class="card-header">
                            <div class="route-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                                    fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                    stroke-linejoin="round">
                                    <circle cx="12" cy="10" r="3" />
                                    <path d="M12 21.7C17.3 17 20 13 20 10a8 8 0 1 0-16 0c0 3 2.7 7 8 11.7z" />
                                </svg>
                            </div>
                            <div>
                                <h3>z Krakowa</h3>
                                <span class="destination-subtext">Kierunek: Krzywaczka, Sułkowice, Harbutowice</span>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="time-display" id="next-sulkowice-time">
                                <span class="loader"></span>
                            </div>
                            <div class="time-notes" id="next-sulkowice-notes">Wczytywanie...</div>
                        </div>
                        <div class="card-footer" id="following-sulkowice-info">
                            Następny: 67:67
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Legend Section -->
        <section class="legend-section">
            <div class="container">
                <h4>Legenda oznaczeń:</h4>
                <ul class="legend-list" id="legend-dynamic-list">
                    <!-- Dynamicznie wczytywane z API -->
                </ul>
            </div>
        </section>

        <!-- News Section -->
        <section class="news-section" id="aktualnosci">
            <div class="container">
                <div class="section-header reveal reveal-up">
                    <h2 class="section-title">Aktualności</h2>
                    <div class="title-underline"></div>
                </div>

                <div class="news-container" id="news-container">
                    <p class="text-center">Wczytywanie komunikatów...</p>
                </div>
            </div>
        </section>

        <!-- FAQ Section (GEO Optimization) -->
        <section class="faq-section" id="faq">
            <div class="container">
                <div class="section-header reveal reveal-up">
                    <h2 class="section-title">Często zadawane pytania (FAQ)</h2>
                    <div class="title-underline"></div>
                </div>

                <div class="faq-container" id="faq-dynamic-container">
                    <!-- Dynamicznie ładowane z API -->
                    <p class="text-center">Wczytywanie pytań...</p>
                </div>
            </div>
        </section>
    </main>

    <!-- Schedule Modal -->
    <div class="modal-overlay" id="schedule-modal">
        <div class="modal-content">
            <button class="modal-close" id="modal-close" aria-label="Zamknij">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
            <h3 class="modal-title">Rozkład Jazdy</h3>
            <img src="/rozklad-current" alt="Rozkład jazdy busów" class="modal-image" loading="lazy" width="800" height="600">
        </div>
    </div>

    <script src="/schedule.js?v=2" defer></script>
    <script src="/news.js?v=3" defer></script>
    <script src="/faq.js?v=2" defer></script>

    <%- include('partials/footer') %>